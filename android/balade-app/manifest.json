{
  "id": "com.mon50ccetmoi.twa",
  "lang": "fr-FR",
  "dir": "ltr",
  "name": "mon50ccetmoi",
  "short_name": "mon50ccetmoi",
  "description": "Navigation et Sécurité Communautaire pour Scooters 50cc. Itinéraires sans autoroute et détection de chute intelligente.",
  "start_url": "./index.html",
  "scope": "./",
  "scope_extensions": [
    { "origin": "*.github.io" }
  ],
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait",
  "background_color": "#0a0a0a",
  "theme_color": "#ffb703",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "prefer_related_applications": true,
  "related_applications": [
    {
      "platform": "play",
      "id": "com.mon50ccetmoi.twa",
      "url": "https://play.google.com/store/apps/details?id=com.mon50ccetmoi.twa"
    }
  ],
  "iarc_rating_id": "mon50cc-2026-v11",
  "categories": ["navigation", "lifestyle", "social", "utilities"],
  "shortcuts": [
    {
      "name": "Mon Garage",
      "short_name": "Garage",
      "description": "Suivi de maintenance et garage virtuel",
      "url": "./index.html?shortcut=garage",
      "icons": [{ "src": "icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Signaler un Danger",
      "short_name": "Danger",
      "description": "Signaler un obstacle ou un contrôle sur la route",
      "url": "./index.html?shortcut=danger",
      "icons": [{ "src": "icon-192x192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "./index.html?share=1",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+mon50cc",
      "url": "./index.html?uri=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/gpx+xml": [".gpx"],
        "application/vnd.google-earth.kml+xml": [".kml"],
        "application/json": [".json"]
      }
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "icons": [
    {
      "src": "icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshot_gps.jpg",
      "sizes": "1024x1024",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Interface GPS mon50ccetmoi"
    },
    {
      "src": "screenshot_garage.jpg",
      "sizes": "1024x1024",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Gestion du Garage et Maintenance"
    },
    {
      "src": "screenshot_wide.jpg",
      "sizes": "1024x1024",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Tableau de bord Communautaire"
    }
  ]
}
